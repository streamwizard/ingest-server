# Copy to .env and fill in before `docker compose up`.

# Doppler service token for the control plane (supplies SUPABASE_URL,
# SUPABASE_SECRET_KEY, SENTRY_DSN, etc.). Create in Doppler for the
# ingest_control config.
DOPPLER_TOKEN=dp.st.xxxxx

# Shared secret between the media plane and control plane for /internal/* calls.
# Generate with: openssl rand -hex 32
INGEST_CONTROL_SECRET=replace-me

# The VM's Tailscale address. The :9000 SRT output port (OBS pulls from it)
# binds ONLY to this interface, so it never faces the public internet. Leave
# empty for local testing to publish on all interfaces.
TAILSCALE_IP=

# ws-server base URL — the control plane connects as a "bot" client to fan out
# live ingest stats. If unset, live broadcast is silently skipped (durable
# history via Supabase still works). e.g. ws://host.docker.internal:8000 locally.
WS_SERVER_URL=
