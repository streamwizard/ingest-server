# ============================================================
# StreamWizard Ingest Server — Environment Variables
# Copy this file to .env and fill in your values.
# Local Supabase values are shown by running: supabase start
# ============================================================

# General
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────
# Local: http://127.0.0.1:54321 | Cloud: https://<project>.supabase.co
SUPABASE_URL=

# Service role key — never expose this publicly
# Local: printed by `supabase start` as "service_role key"
SUPABASE_SECRET_KEY=

# ── Internal Auth ────────────────────────────────────────────
# Shared secret the media plane must present on every internal call.
# Generate with: openssl rand -hex 32
INGEST_CONTROL_SECRET=

# ── Fleet identity ───────────────────────────────────────────
# ingest_nodes.id, returned by the claim flow (docs/PANEL_INTEGRATION.md).
# Tags this node's host system metrics (CPU/RAM/bandwidth) in InfluxDB.
INGEST_NODE_ID=

# ── ingest-control ───────────────────────────────────────────
# HTTP port for the control plane (default: 8090)
PORT=8090

# ── ingest-media ─────────────────────────────────────────────
# Base URL of the control plane reachable from the media container.
# e.g. http://localhost:8090 locally or http://ingest-control:8090 in Docker.
INGEST_CONTROL_URL=

# Public SRT ingest port (streamers connect here)
INGEST_SRT_PORT=8888
# Internal SRT port for Belabox srtla_receiver connections
INGEST_SRTLA_SRT_PORT=8889
# SRT output port OBS pulls from (bound to Tailscale interface in prod)
INGEST_OUTPUT_PORT=9000
# SRT receiver-buffer latency in milliseconds
INGEST_SRT_LATENCY_MS=4000
# Seconds to wait for control plane before rejecting a connection
INGEST_CONTROL_TIMEOUT=5
# Log level for the media plane (DEBUG, INFO, WARNING, ERROR)
INGEST_LOG_LEVEL=INFO

# ── Network ──────────────────────────────────────────────────
# Tailscale IP of this VPS — the SRT output port is bound to this interface
# so it is never exposed to the public internet. Run: tailscale ip -4
TAILSCALE_IP=

# ── Internal Service URLs ────────────────────────────────────
# WebSocket server base URL — control plane connects as a "bot" client to fan
# out live ingest stats. If unset, live broadcast is silently skipped.
# e.g. ws://localhost:8000 locally
WS_SERVER_URL=

# ── InfluxDB (optional) ───────────────────────────────────────
# Time-series sink for per-stream ingest metrics + host system metrics
# (CPU/RAM/bandwidth). All four vars must be set to enable; omit or leave
# blank to disable metrics entirely. One shared InfluxDB instance across
# environments — set BUCKET to streamwizard-dev / streamwizard-staging /
# streamwizard-prod to match this node's environment.
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# ── Sentry (optional) ────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
