{
  "name": "streamwizard-ingest",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently --kill-others-on-fail -n control,media -c blue,green \"bun run dev:control\" \"bun run dev:media\"",
    "dev:control": "doppler run -- turbo run dev --filter=@repo/ingest-control",
    "dev:media": "cd apps/ingest-media/src && doppler run -- python3 -m ingest_media",
    "compose:up": "docker compose -f docker/stream-server/docker-compose.yml up --build",
    "compose:down": "docker compose -f docker/stream-server/docker-compose.yml down",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "bun x turbo run check-types"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "prettier": "^3.7.4",
    "shadcn": "^4.11.0",
    "turbo": "^2.9.15",
    "typescript": "5.9.2"
  },
  "overrides": {
    "next": "^16.2.6",
    "@sentry/core": "10.56.0",
    "@sentry/bun": "10.56.0",
    "@sentry/hono": "10.56.0",
    "dompurify": "^3.4.7"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "server-only": "^0.0.1"
  }
}
